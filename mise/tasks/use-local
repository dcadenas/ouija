#!/bin/bash
# Install ouija from local source, restart daemon
set -euo pipefail

echo "Building from local source..."
# Touch main.rs to force recompilation — cargo install --force reuses cached
# build artifacts and may skip recompiling changed source files.
touch src/main.rs
cargo install --path . --force

# Clean crates.io marker if present
rm -f ~/.local/share/ouija/.published

CARGO_BIN="$HOME/.cargo/bin/ouija"
LOCAL_BIN="$HOME/.local/bin/ouija"

# mise prepends ~/.cargo/bin to PATH, so `which ouija` inside this task cannot
# detect a ~/.local/bin copy that will shadow the fresh build in normal shells.
if [ -f "$LOCAL_BIN" ] && [ "$LOCAL_BIN" != "$CARGO_BIN" ]; then
    cp "$CARGO_BIN" "$LOCAL_BIN"
fi

# systemd/legacy-aware restart (replaces the old broken `ouija stop`/`ouija start`).
"$CARGO_BIN" restart-server
echo "Running local build: $("$CARGO_BIN" status | grep -o '"version":"[^"]*"' | head -1 | cut -d'"' -f4)"
