#!/bin/bash
# Release a stable version, commit, tag, push, publish to crates.io, then ouija update.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

PORT="${OUIJA_PORT:-7880}"
BASE="http://localhost:${PORT}"
NEXT="${OUIJA_RELEASE_VERSION:-0.1.0}"

if [[ ! "$NEXT" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "error: stable release version must be major.minor.patch, got: $NEXT" >&2
  exit 1
fi

if [ "${OUIJA_RELEASE_MAC_DRY_RUN:-}" != "1" ] && [ -n "$(git -C "$REPO_DIR" status --porcelain)" ]; then
  echo "error: working tree must be clean before release" >&2
  exit 1
fi

CURRENT=$(grep '^version' "$REPO_DIR/Cargo.toml" | head -1 | sed 's/.*"\(.*\)"/\1/')
echo "Current version: $CURRENT"
echo "Stable version: $NEXT"

find_macos_node() {
  local nodes_json
  nodes_json="$(curl -sf "${BASE}/api/nodes" 2>/dev/null || true)"
  if [ -z "$nodes_json" ]; then
    return 0
  fi

  jq -r '[.nodes[] | select(.name != null and .status == "connected") | .name] | first // empty' <<<"$nodes_json" 2>/dev/null || true
}

macos_build_message() {
  local version="$1"
  cat <<EOF
Release v${version} published. Build macOS binaries and upload to the GitHub release.

Steps:
1. cd ~/code/ouija && git pull
2. cargo build --release --target x86_64-apple-darwin
3. cargo build --release --target aarch64-apple-darwin
4. for TARGET in x86_64-apple-darwin aarch64-apple-darwin; do DIR="ouija-\$TARGET"; mkdir -p "\$DIR"; cp "target/\$TARGET/release/ouija" "\$DIR/"; tar cJf "\$DIR.tar.xz" "\$DIR"; rm -rf "\$DIR"; done
5. while ! gh release view v${version} --repo dcadenas/ouija >/dev/null 2>&1; do echo waiting for release...; sleep 15; done
6. gh release upload v${version} --repo dcadenas/ouija ouija-x86_64-apple-darwin.tar.xz ouija-aarch64-apple-darwin.tar.xz
7. rm -f ouija-x86_64-apple-darwin.tar.xz ouija-aarch64-apple-darwin.tar.xz

IMPORTANT: do NOT use gh release create. Only use gh release upload. The CI workflow creates the release.
EOF
}

send_macos_build_request() {
  local version="$1"
  local mac_node="$2"
  local message
  message="$(macos_build_message "$version")"

  if [ "${OUIJA_RELEASE_MAC_DRY_RUN:-}" = "1" ]; then
    printf 'target=%s/ouija\n' "$mac_node"
    printf 'message<<EOF\n%s\nEOF\n' "$message"
    return 0
  fi

  curl -sf -X POST "${BASE}/api/send" \
    -H "Content-Type: application/json" \
    -d "$(jq -n \
      --arg from "release-task" \
      --arg to "${mac_node}/ouija" \
      --arg message "$message" \
      '{from: $from, to: $to, message: $message, expects_reply: false}')"
}

request_macos_builds() {
  local version="$1"
  local mac_node
  mac_node="$(find_macos_node)"

  if [ -z "$mac_node" ]; then
    echo "warning: no remote Mac node connected, skipping macOS builds"
    return 0
  fi

  echo "Requesting macOS builds from ${mac_node}..."
  if send_macos_build_request "$version" "$mac_node"; then
    if [ "${OUIJA_RELEASE_MAC_DRY_RUN:-}" = "1" ]; then
      echo "macOS build request dry-run complete"
    else
      echo "macOS build request sent"
    fi
  else
    echo "warning: could not send macOS build request"
  fi
}

if [ "${OUIJA_RELEASE_MAC_DRY_RUN:-}" = "1" ]; then
  request_macos_builds "$NEXT"
  exit 0
fi

if [[ "$(uname)" == "Darwin" ]]; then
  sed -i '' "s/^version = \"$CURRENT\"/version = \"$NEXT\"/" "$REPO_DIR/Cargo.toml"
else
  sed -i "s/^version = \"$CURRENT\"/version = \"$NEXT\"/" "$REPO_DIR/Cargo.toml"
fi
cargo check --quiet --manifest-path "$REPO_DIR/Cargo.toml" 2>/dev/null || true

git -C "$REPO_DIR" add Cargo.toml Cargo.lock
git -C "$REPO_DIR" commit -m "v$NEXT"
git -C "$REPO_DIR" tag "v$NEXT"
git -C "$REPO_DIR" push && git -C "$REPO_DIR" push origin "v$NEXT"

cargo publish --manifest-path "$REPO_DIR/Cargo.toml"

ouija self-update
request_macos_builds "$NEXT"

echo "Released $NEXT"
